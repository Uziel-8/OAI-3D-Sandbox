dialogue_lines = Array[String](["You've no business on my docks. State it or clear off.", "Whatever the dockmaster's paying you, it's not worth crossing me. I've a hundred men on this waterfront and every one of them owes me.", "...Go on, then. But you'll not find me an easy man to be rid of."])
