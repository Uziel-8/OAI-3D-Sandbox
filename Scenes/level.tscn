script = ExtResource("8_lvlobj")
objective_title = "Remove the Foreman"
objective_text = "The dockmaster wants Karrick, the yard foreman, gone from the port — quietly or otherwise. Force, bribery, persuasion, or misdirection; the method is yours to choose."
journal_entries = Array[ExtResource("9_entry")]([SubResource("Entry_docks"), SubResource("Entry_telekinesis")])

