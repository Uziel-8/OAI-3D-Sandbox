[sub_resource type="Resource" id="Entry_docks"]
script = ExtResource("9_entry")
title = "Arrival at the Docks"
body = "Salt, tar, and rot. The harbour district runs on cheap labour and cheaper loyalty, its warehouses stacked to the rafters with crates nobody asks about.

Barrels everywhere — some full, some not. Worth remembering that a heavy thing dropped from a height asks no questions."
category = "Lore"

[sub_resource type="Resource" id="Entry_telekinesis"]
script = ExtResource("9_entry")
title = "On the Art of Telekinesis"
body = "The Force discipline is blunt but honest: what you can see, you can shove. Reach out to hold a thing at arm's length, then release to send it flying. A firm push clears a path — or a person.

The scholars insist there is subtlety to be learned. For now, there is leverage."
category = "Lore"

